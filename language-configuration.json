{
    "comments": {
        "lineComment": "#"
    },
    "autoClosingPairs": [
        { "open": "{", "close": "}" },
        { "open": "[", "close": "]" },
        { "open": "(", "close": ")" },
        { "open": "\"", "close": "\"", "notIn": ["string"] },
        { "open": "'", "close": "'", "notIn": ["string"] },
        { "open": "<", "close": ">", "notIn": ["string"] }
    ],
    "surroundingPairs": [
        { "open": "{", "close": "}" },
        { "open": "[", "close": "]" },
        { "open": "(", "close": ")" },
        { "open": "\"", "close": "\"" },
        { "open": "'", "close": "'" },
        { "open": "<", "close": ">" }
    ],
    "folding": {
        "markers": {
            "start": "^\\s*(?:Feature|Rule|Background|Scenario(?: Outline)?|Examples):",
            "end": "^\\s*$"
        }
    }
}
